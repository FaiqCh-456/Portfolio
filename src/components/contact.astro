<section id="contact" class="w-full py-12 border-t border-[#ffffff10]">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">Let's talk</h2>
    <h3 class="text-4xl md:text-5xl font-medium text-[var(--white)] mb-6">
      Contact
    </h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      
      <!-- Left side info -->
      <div class="text-[var(--white-icon)]">
        <p class="mb-4">
          Have a question or a project in mind? Feel free to reach out.
        </p>
        <div class="flex items-center gap-2">
          <span>📍 Location:</span>
          <span class="text-[var(--white)]">Lahore, Pakistan</span>
        </div>
        <div class="flex items-center gap-2 mt-2">
          <span>✉️ Email:</span>
          <span class="text-[var(--white)]">faiqyousaf25@gmail.com</span>
        </div>

        <!-- Resume Section -->
        <div class="mt-6">
          <h4 class="text-lg font-medium text-[var(--white)] mb-2">
            📄 Here’s my Resume
          </h4>
          <a 
            href="https://drive.google.com/file/d/1nEadgMRRSGEwZierMZ7S0mb4SvZ8PyEy/view?usp=sharing" 
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-4 py-2 bg-[var(--sec)] text-[var(--white)] rounded-lg transition-all border border-[var(--sec)] hover:bg-[var(--sec-hover)]"
          >
            View Resume
          </a>
        </div>
      </div>

      <!-- Right side form -->
      <div>
        <form
          id="contact-form"
          action="https://formspree.io/f/xnnzebab"
          method="POST"
          class="flex flex-col gap-4"
        >
          <input
            type="text"
            name="from_name"
            placeholder="Name"
            required
            class="px-4 py-2 bg-[#1414149c] text-[var(--white)] border border-[var(--white-icon-tr)] rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--sec)] transition-all"
          />
          <input
            type="email"
            name="reply_to"
            placeholder="Email"
            required
            class="px-4 py-2 bg-[#1414149c] text-[var(--white)] border border-[var(--white-icon-tr)] rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--sec)] transition-all"
          />
          <textarea
            name="message"
            placeholder="Message"
            rows="6"
            required
            class="px-4 py-2 bg-[#1414149c] text-[var(--white)] border border-[var(--white-icon-tr)] rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--sec)] resize-none transition-all"
          ></textarea>
          <button
            id="submit-btn"
            type="submit"
            class="flex items-center justify-center gap-2 px-4 py-2 bg-[var(--sec)] text-[var(--white)] rounded-lg transition-all border border-[var(--sec)] hover:bg-[var(--sec-hover)]"
          >
            <span id="btn-text">Submit</span>
            <span
              id="btn-loader"
              class="hidden w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin"
            ></span>
          </button>
        </form>

        <!-- Success message -->
        <div
          id="form-success"
          class="hidden mt-4 p-4 text-green-400 bg-green-900/20 border border-green-500 rounded-lg animate-fadeIn"
        >
          ✅ Thank you for your message! I’ll get back to you soon.
        </div>

        <!-- Error message -->
        <div
          id="form-error"
          class="hidden mt-4 p-4 text-red-400 bg-red-900/20 border border-red-500 rounded-lg animate-fadeIn"
        >
          ❌ Oops! Something went wrong. Please try again.
        </div>
      </div>
    </div>
  </div>
</section>
